TELEGRAM_BOT_TOKEN=your_bot_token_here
USER_ID=your_telegram_user_id_here

# Proxy (optional)
# Examples:
# HTTP_PROXY_URL=http://user:pass@proxy_host:3128
# HTTPS_PROXY_URL=http://user:pass@proxy_host:3128
# NO_PROXY=api.telegram.org,localhost
HTTP_PROXY_URL=
HTTPS_PROXY_URL=
PROXY_URL=
NO_PROXY=
# If you use a SOCKS5 or a proxy that is configured via ALL_PROXY, set it here:
# ALL_PROXY_URL=socks5://user:pass@proxy_host:PORT
ALL_PROXY_URL=
